#!/bin/bash
# =============================================================================
# genEStim — Generate Intan RHS stimulation specs and write them to the DB.
#
# Invocation: ./genEStim          (uses the PARAMS string below)
#
# -----------------------------------------------------------------------------
# STYLING GUIDE — How to build a PARAMS string
# -----------------------------------------------------------------------------
# Format: 'key=value. key=value. key=value'   (parameters separated by ". ")
#
# Required:
#   channels=[A020, A011]              List of stim channels (port + 3-digit num).
#                                      Channels NOT listed here become ground-only
#                                      channels on port A (zero-amplitude pulses).
#
# Splits (cartesian product):
#   Wrap any value in {a;b;c} to generate one spec per value.
#   e.g. polarity={NegativeFirst;PositiveFirst} produces two specs.
#   Stacking multiple splits produces all combinations.
#
# -----------------------------------------------------------------------------
# WAVEFORM PARAMETERS
# -----------------------------------------------------------------------------
#   shape       StimulationShape: Biphasic | BiphasicWithInterphaseDelay |
#                                 Triphasic | Monophasic
#               (default: BiphasicWithInterphaseDelay)
#   polarity    NegativeFirst | PositiveFirst  (default: NegativeFirst)
#   d=(d1,d2)   First/second phase duration in MICROSECONDS  (default: 200,200)
#   d1, d2      Individual overrides in MICROSECONDS
#   dp          Interphase delay in MICROSECONDS              (default: 100)
#   a=(a1,a2)   First/second phase amplitude in MICROAMPS     (default: 2.5,2.5)
#   a1, a2      Individual overrides in MICROAMPS
#
# -----------------------------------------------------------------------------
# PULSE TRAIN PARAMETERS  (the part that changed — read this carefully)
# -----------------------------------------------------------------------------
# The new default paradigm is Edge-triggered PulseTrain. On the rising edge of
# the digital trigger line, Intan fires a fixed-count train of pulses at the
# specified frequency, independent of whether the trigger is held high.
#
#   triggerType         Edge | Level                          (default: Edge)
#
#     Edge:  Defaults to PulseTrain. Train fires once per rising edge.
#            Holding the trigger high longer does NOT extend the train.
#            Pulse count is bounded by `duration` (or `numPulses`).
#
#     Level: Defaults to SinglePulse — THIS IS THE OLD "HOLD" PARADIGM.
#            Each held tick fires one pulse, then pulseWidth + refractoryPeriod
#            + triggerDelay elapses, then if still held, the next pulse fires.
#            Total firing duration is controlled by how long the trigger is held.
#            In Level mode you specify the pulse RATE via `freq` (which auto-
#            computes refractoryPeriod), OR you set refractoryPeriod directly
#            the way you used to. `duration` and `numPulses` are ignored here.
#
#   pulseRepetition     PulseTrain | SinglePulse              (optional override)
#                       By default determined by triggerType (see above). Set
#                       this only if you want a non-default combination, e.g.
#                       Level + PulseTrain (train auto-restarts while held).
#
#   freq                Pulse frequency in HZ                 (default: 200)
#                       Edge/PulseTrain: pulse train period = 1 / freq.
#                       Level/SinglePulse: AUTO-COMPUTES refractoryPeriod so the
#                       pulse-to-pulse rate while held matches freq.
#                       Formula: refractoryPeriod = 1/freq - pulseWidth - triggerDelay.
#                       Errors if freq is too high for the given pulse width
#                       plus triggerDelay.
#                       If you ALSO specify refractoryPeriod / refractoryPeriodMs,
#                       that overrides the freq calc.
#
#   duration            Target train duration in MILLISECONDS (default: 200)
#                       Only used in PulseTrain mode. Ignored in SinglePulse mode.
#                       numPulses is computed as floor(duration / period).
#                       Constraints:
#                         - Intan caps trains at 256 pulses. If duration would
#                           require more, the program FAILS with a message
#                           telling you the max duration possible at that freq.
#                         - If duration is not an integer multiple of the
#                           period, the program WARNS and rounds DOWN to the
#                           nearest whole number of pulses, telling you the
#                           actual duration achieved.
#
#   numPulses           OVERRIDE: explicitly set pulse count, ignoring duration.
#                       Capped at 256. PulseTrain mode only.
#
#   triggerDelayMs      Post-trigger delay in MILLISECONDS    (default: 100)
#                       Time from the rising trigger edge to the first pulse.
#                       Edge: purely a one-shot startup delay; does NOT add to
#                         refractory or pulse spacing. Set as long as you want.
#                       Level: paid on every pulse cycle. Adds to the pulse-to-
#                         pulse spacing (this is the OLD coupling between
#                         triggerDelay and refractory that you ran into before).
#
#   refractoryPeriodMs  Post-train refractory in MILLISECONDS (default: 100)
#                       PulseTrain: time after train completes before another
#                         trigger is accepted (charge recovery runs here).
#                       SinglePulse: the gap between successive pulses while
#                         held. This is what your old PARAMS controlled
#                         directly with `refractoryPeriod=8000`.
#
# Legacy aliases (still accepted, both interpret value as MICROSECONDS):
#   triggerDelay        Same as triggerDelayMs but in µs.
#   refractoryPeriod    Same as refractoryPeriodMs but in µs.
#
# -----------------------------------------------------------------------------
# GROUNDING (charge recovery on non-stim channels)
# -----------------------------------------------------------------------------
#   groundMode    PostTrain | BetweenPulse                    (default: PostTrain)
#
#     PostTrain:    Ground-only channels mirror the stim train exactly, at zero
#                   amplitude. Charge recovery happens AFTER the train completes
#                   (this is an Intan RHS hardware limitation — you cannot
#                   charge-recover between pulses within a single train).
#                   Use when you don't need per-pulse grounding.
#
#     BetweenPulse: Ground-only channels are configured as Level + SinglePulse,
#                   with refractory sized so each ground pulse fires between
#                   successive stim pulses. This reproduces the original
#                   "edge hold to ground" paradigm.
#                   IMPORTANT: this requires a HELD-HIGH trigger spanning the
#                   stim train duration. Since stim channels run Edge-triggered
#                   trains (which fire once on the rising edge and ignore the
#                   held level), you must arrange the trigger pulse so its
#                   held duration matches the stim train duration. Verify
#                   timing on a scope before relying on it.
#
# -----------------------------------------------------------------------------
# EXAMPLES
# -----------------------------------------------------------------------------
#   # ─── NEW EDGE-TRIGGERED PARADIGM ───
#   # Defaults: Edge + PulseTrain, 200 Hz, 200 ms (40 pulses), 100 ms trigger
#   # delay, 100 ms refractory, PostTrain ground.
#   PARAMS='channels=[A020, A011]'
#
#   # Sweep polarity, custom amplitude (still Edge default):
#   PARAMS='channels=[A020, A011]. polarity={PositiveFirst;NegativeFirst}. a=(3.5, 3.5)'
#
#   # 100 ms train at 100 Hz, between-pulse grounding (requires held trigger
#   # spanning the train; see GROUNDING section above):
#   PARAMS='channels=[A020]. freq=100. duration=100. groundMode=BetweenPulse'
#
#   # ─── OLD LEVEL/HOLD PARADIGM — exact equivalent of your previous setup ───
#   # Old script was:
#   #   refractoryPeriod=8000. triggerDelay=100
#   # Translation #1 — keep specifying refractoryPeriod directly (most exact):
#   PARAMS='channels=[A020, A011]. polarity={PositiveFirst;NegativeFirst}. a=(3.5, 3.5). triggerType=Level. refractoryPeriod=8000. triggerDelay=100. groundMode=BetweenPulse'
#
#   # Translation #2 — same paradigm but specify pulse rate as a frequency
#   # instead of a raw refractory. At a 200 µs + 100 µs + 200 µs = 500 µs
#   # pulse width and 100 µs triggerDelay, refractoryPeriod=8000 µs corresponds
#   # to ~116 Hz. Letting freq drive it:
#   PARAMS='channels=[A020, A011]. polarity={PositiveFirst;NegativeFirst}. a=(3.5, 3.5). triggerType=Level. freq=116. triggerDelay=100. groundMode=BetweenPulse'
#
#   # ─── ADVANCED ───
#   # Force Level + PulseTrain (train auto-restarts while held):
#   PARAMS='channels=[A020]. triggerType=Level. pulseRepetition=PulseTrain. freq=200. duration=50'
#
# =============================================================================

source version
source paths
sudo -S <<< Whedon101 cp $XPER_PROPERTIES_PROCEDURAL $DIST/xper.properties
sudo -S <<< Whedon101 cp $XPER_PROPERTIES_PROCEDURAL $DIST/allen/xper.properties
cd $DIST/allen

PARAMS='channels=[A009, A023, A015]. polarity={PositiveFirst;NegativeFirst}. a=(3.33, 3.33). triggerType=Edge. freq=100. duration=460. triggerDelayMs=40. groundMode=PostTrain'

